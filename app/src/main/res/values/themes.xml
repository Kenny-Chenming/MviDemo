<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme (used when system is in Light mode) -->
    <style name="Theme.MyMviProject" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Dark theme -->
    <style name="Theme.MyMviProject.Dark" parent="android:Theme.Material.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
